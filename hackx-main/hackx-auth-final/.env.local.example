# ─── MongoDB ───────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/sehat-setu

# ─── NextAuth ──────────────────────────────────────────────────────────────
# REQUIRED: Set to your deployed URL (http://localhost:3000 for local dev)
NEXTAUTH_URL=http://localhost:3000

# REQUIRED: Generate with:  openssl rand -base64 32
NEXTAUTH_SECRET=your-strong-random-secret-here

# ─── Legacy JWT (still used by /api/auth/login REST endpoint) ─────────────
JWT_SECRET=your-strong-random-secret-here

# ─── Google Maps (Nearby Medical Stores) ────────────────────────────────────
# Get API key from: https://console.cloud.google.com/google/maps-apis
# Required APIs: Maps JavaScript API, Places API, Geolocation API
GOOGLE_MAPS_API_KEY=your-google-maps-api-key-here

# ─── Groq AI ─────────────────────────────────────────────────────────
GROQ_API_KEY=gsk_your_api_key_here

# ─── Fast2SMS (OTP SMS) ────────────────────────────────────────────────────
# Sign up free at https://www.fast2sms.com → Dashboard → Dev API
# You get ₹50 free credits on signup (~200 OTPs)
FAST2SMS_API_KEY=your-fast2sms-api-key-here

# ─── Pusher (WebRTC Signaling) ─────────────────────────────────────────────
# Sign up free at https://pusher.com → Create Channels App → Keys
# Free tier: 100 concurrent connections, unlimited messages
PUSHER_APP_ID=your-pusher-app-id
NEXT_PUBLIC_PUSHER_KEY=your-pusher-app-key
PUSHER_APP_SECRET=your-pusher-app-secret
NEXT_PUBLIC_PUSHER_CLUSTER=your-pusher-cluster (e.g., ap2, us2, eu)

# ─── Google Sheets Integration (Service Account) ─────────────────────────────
# 1. Create a Service Account in Google Cloud Console
# 2. Enable Google Sheets API
# 3. Share your Sheet with the Service Account email
GOOGLE_CLIENT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"
GOOGLE_SHEET_ID=your-google-sheet-id
